#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Fetch latest changes
git fetch origin main

# Reset to main but keep changes
git reset --soft origin/main

# Get commit message from user
echo "Enter commit message for squashed commit: "
read commit_message

# Use the entered commit message
git commit -m "$commit_message"

echo "✅ All commits squashed into one with message: '$commit_message'. Starting rebase..."

# Start interactive rebase with autosquash
git rebase -i --autosquash origin/main